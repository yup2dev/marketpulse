# ===================================
# MarketPulse Environment Variables
# ===================================
# 이 파일을 복사하여 .env 파일로 사용하세요
# cp .env.example .env

# ===== Application =====
APP_NAME=MarketPulse
APP_VERSION=1.0.0
DEBUG=true

# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== Fetcher (로컬 데스크톱 앱) =====
# 활성화 시 백엔드는 provider 호출을 Fetcher(exe)에 위임한다
FETCHER_REMOTE_ENABLED=false
# Fetcher 실행 시 로그/키 관리 UI(http://127.0.0.1:8765/)에 표시되는 토큰을 그대로 입력
# (워커 모드에서는 사용자 PC Fetcher와 이 토큰이 동일해야 한다)
FETCHER_TOKEN=

# false(기본): 백엔드 → FETCHER_URL로 직접 HTTP 호출(pull). 같은 PC/LAN에 Fetcher가 있을 때.
# true: 사용자 PC의 Fetcher가 /ws/fetcher 로 outbound 접속(push)하는 워커 풀에 위임.
#       NAT/방화벽 뒤의 PC도 동작 가능 (FETCHER_URL 불필요).
FETCHER_WORKER_MODE=false
FETCHER_URL=http://127.0.0.1:8765

# ===== Database =====
# PostgreSQL (프로덕션)
# DATABASE_URL=postgresql://marketpulse:your_password@localhost:5432/marketpulse

# SQLite (개발용 - DATABASE_URL이 없으면 자동 사용)
# SQLITE_PATH=./data/marketpulse.db

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ===== Redis =====
# Redis 연결 URL (비활성화 시 인메모리 캐시로 자동 대체)
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://:your_password@localhost:6379/0   # 인증 있을 때

# Redis 기능 활성화 (false면 인메모리 캐시만 사용)
QUEUE_ENABLED=true

# 종목 리스트 캐시 TTL (초, 기본 3600 = 1시간)
# STOCK_LIST_CACHE_TTL=3600

# 종목 리스트 백그라운드 갱신 주기 (초, 기본 300 = 5분)
# STOCK_LIST_REFRESH_INTERVAL=300

# ===== Scheduler Settings =====
# 스케줄러 활성화 여부
SCHEDULER_ENABLED=true

# 뉴스 크롤링 주기 (시간)
CRAWL_INTERVAL_HOURS=1

# 감성 분석 주기 (시간)
SENTIMENT_INTERVAL_HOURS=2

# 마켓 데이터 동기화 주기 (시간)
MARKET_DATA_INTERVAL_HOURS=6

# ===== API Keys =====
# FRED API (Federal Reserve Economic Data)
# https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_api_key

# Yahoo Finance API (선택)
# YAHOO_FINANCE_API_KEY=your_yahoo_finance_key

# Alpha Vantage API (선택)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# OpenAI API (선택 - 고급 NLP 기능)
# OPENAI_API_KEY=sk-your_openai_key

# AI Copilot — 키는 웹 '설정 → API 키 관리'에서 사용자별로 등록하는 것을 권장.
# 아래는 서버 전역 폴백(선택). Gemini는 aistudio.google.com에서 무료 발급.
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
# COPILOT_MODEL=claude-opus-4-8
# GEMINI_API_KEY=your_gemini_key
# COPILOT_GEMINI_MODEL=gemini-2.5-flash

# ===== Crawler Settings =====
# 크롤러 최대 워커 수
CRAWLER_MAX_WORKERS=5

# HTTP 요청 타임아웃 (초)
CRAWLER_TIMEOUT=30

# 최대 재시도 횟수
CRAWLER_MAX_RETRIES=3

# ===== NLP/ML Settings =====
# Transformers (FinBERT) 사용 여부
# true로 설정하면 transformers 및 torch가 필요합니다
# requirements.txt에서 주석 해제 필요
USE_TRANSFORMERS=false

# ML 모델 캐시 디렉토리
MODEL_CACHE_DIR=./models

# ===== Logging =====
# 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 로그 파일 경로
LOG_FILE=./logs/app.log

# ===================================
# 추가 설정 (Phase 2 - Celery용)
# ===================================

# Celery 브로커 URL (Phase 2에서 사용)
# CELERY_BROKER_URL=redis://:your_redis_password@localhost:6379/0

# Celery 결과 백엔드 (Phase 2에서 사용)
# CELERY_RESULT_BACKEND=redis://:your_redis_password@localhost:6379/0

# ===================================
# Docker Compose 전용 변수
# ===================================
# docker-compose.yml에서 사용

# PostgreSQL
POSTGRES_DB=marketpulse
POSTGRES_USER=marketpulse
POSTGRES_PASSWORD=your_strong_password_here

# JWT Secret (Spring Boot)
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_EXPIRATION=3600000

# ===================================
# 빠른 시작 가이드
# ===================================
#
# 1. 개발 환경 (SQLite + APScheduler):
#    - DATABASE_URL 주석 처리 (자동으로 SQLite 사용)
#    - SCHEDULER_ENABLED=true
#    - USE_TRANSFORMERS=false (빠른 시작)
#
# 2. 프로덕션 환경 (PostgreSQL + APScheduler):
#    - DATABASE_URL 설정
#    - SCHEDULER_ENABLED=true
#    - API 키 설정
#
# 3. Phase 2 (Celery):
#    - Redis 필수
#    - CELERY_BROKER_URL, CELERY_RESULT_BACKEND 설정
#    - requirements.txt에서 celery, redis 주석 해제
#
# ===================================
