{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarketPulse",
  "version": "0.1.0",
  "identifier": "com.marketpulse.desktop",
  "build": {
    "frontendDist": "../../app/frontend/dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "cd ../app/frontend && npm run dev -- --port 5180",
    "beforeBuildCommand": "cd ../app/frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MarketPulse",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "publisher": "MarketPulse",
    "externalBin": [
      "binaries/marketpulse-fetcher"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yup2dev/marketpulse/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": ""
    },
    "shell": {
      "open": true
    }
  }
}
