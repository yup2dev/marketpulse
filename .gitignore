# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ── Claude 메모리 (로컬 작업 노트, 저장소에 불필요) ────────────────────────────
memory/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.mypy_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.log

# ── 가상환경 / 시크릿 ─────────────────────────────────────────────────────────
.env
.venv/
venv/
env/

# ── Python 빌드 결과물 (PyInstaller) ──────────────────────────────────────────
dist/
build/dist/
build/work/

# ── app/frontend ───────────────────────────────────────────────────────────────
node_modules/
app/frontend/dist/
app/frontend/src/lib/

# ── desktop (Tauri) ────────────────────────────────────────────────────────────
desktop/node_modules/
desktop/src-tauri/target/
# sidecar 바이너리 (빌드 산출물)
desktop/src-tauri/binaries/

# ── 프로젝트 데이터 / 캐시 ──────────────────────────────────────────────────────
data/
cache/
logs/
/models/

# ── 기타 ──────────────────────────────────────────────────────────────────────
*.backup
bash.exe.stackdump
/test_*.py
# .claude는 로컬 설정이므로 제외하되, 팀 공유용 스킬은 추적한다
.claude/*
!.claude/skills/
quant_3d_scan.png

# 클라우드 동기화 인증 (daily_ingest.bat)
scripts/sync.env
